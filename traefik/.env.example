# Certificate Configuration
# Options: selfsigned or letsencrypt
CERT_MODE=letsencrypt

# Domain for self-signed certificate (only used when CERT_MODE=selfsigned)
CERT_DOMAIN=localhost

# Validity period for self-signed certificate in days (only used when CERT_MODE=selfsigned)
CERT_DAYS=365

# Directory to store certificates
CERTS_DIR=./certs

# Let's Encrypt Configuration (only used when CERT_MODE=letsencrypt)
LE_EMAIL=your-email@example.com

# Traefik Log Level
LOG_LEVEL=INFO
